{
  "plugins": {
    "supabase": {
      "enabled": true
    }
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/scripts/start-local-supabase.sh"
          }
        ]
      }
    ]
  }
}
